# Load required packages
library(readxl)
library(dplyr)
library(janitor)
knitr::opts_chunk$set(echo = TRUE)
# Load / install required packages
load_pkg <- function(pkg){
if (!require(pkg, character.only = TRUE)) {
install.packages(pkg, dependencies = TRUE)
library(pkg, character.only = TRUE)
}
}
# Load required packages
load_pkg("readxl")
load_pkg("dplyr")
load_pkg("ggplot2")
load_pkg("tidyr")
load_pkg("janitor")
data <- readxl::read_excel("combined_10March_2026.xlsx")
load_pkg("here")
data <- read_excel(here("combined_10March_2026.xlsx"))
data <- read_excel(here("raw data/combined_10March_2026.xlsx"))
glimpse(data)
str(data)
data <- data %>% clean_names()
names(data)
# Structure and basic summary
str(data)
summary(data)
# Converting inconsistent "N/A" and "-" strings to NA
data <- data %>% mutate(across(everything(), ~ ifelse(. %in% c("N/A", "-", ""), NA, .)))
# Structure and basic summary
str(data)
sum(duplicated(data))
data <- data %>% distinct()
sum(duplicated(data)) #
factor_vars <- c("individual_id", "sex", "age", "origin", "strain", "condition", "trial_day", "background_colou", "housing_s", "housing_social")
data <- data %>%
mutate(across(all_of(factor_vars), as.factor))
factor_vars <- c("individual_id", "sex", "age", "origin", "strain", "condition", "trial_day", "background_colour", "housing_s", "housing_social")
data <- data %>%
mutate(across(all_of(factor_vars), as.factor))
# Structure
str(data)
number_vars <- c( "latency_swim_freely", "timespent_contact" ,"timespent_active", "nb_dart_startle", "distance_no","latency_approach_no", "latency_touch_no", "luminosity", "photoperiod", "salinity")
data <- data %>%
mutate(across(all_of(number_vars), as.numeric))
# Structure
str(data)
summary(data)
# Structure
str(data)
data %>% count(study_species) %>%
ggplot(aes(x = study_species, y = n)) +
geom_col(fill="cornflowerblue") +
labs(title="Count by Sex", x="Sex", y="Count")
data %>% count(study_species) %>%
ggplot(aes(x = study_species, y = n)) +
geom_col() +
labs(title="Count by Species", x="Species", y="Count")
data %>% count(study_species) %>%
ggplot(aes(x = study_species, y = n, fill= study_species)) +
geom_col() +
labs(title="Count by Species", x="Species", y="Count")
knitr::opts_chunk$set(echo = TRUE)
# Load / install required packages
load_pkg <- function(pkg){
if (!require(pkg, character.only = TRUE)) {
install.packages(pkg, dependencies = TRUE)
library(pkg, character.only = TRUE)
}
}
# Load required packages
load_pkg("readxl")
load_pkg("dplyr")
load_pkg("ggplot2")
load_pkg("tidyr")
load_pkg("janitor")
load_pkg("here")
load_pkg("ggpubr")
load_pkg("knitr")
data <- read_excel(here("raw data/combined_10March_2026.xlsx"))
str(data)
data <- data %>% clean_names()
names(data)
# Structure
str(data)
# Converting inconsistent "N/A" and "-" strings to NA
data <- data %>% mutate(across(everything(), ~ ifelse(. %in% c("N/A", "-", ""), NA, .)))
# checking for duplicate rows
sum(duplicated(data)) # 2 not so bad, probably happended when copying over. remove:
data <- data %>% distinct()
# as per structure, many variable are character but should be either numeric or factors
# converting to factors:
factor_vars <- c("individual_id", "sex", "age", "origin", "strain", "condition", "trial_day", "background_colour", "housing_s", "housing_social")
data <- data %>%
mutate(across(all_of(factor_vars), as.factor))
# converting to numeric:
number_vars <- c( "latency_swim_freely", "timespent_contact" ,"timespent_active", "nb_dart_startle", "distance_no","latency_approach_no", "latency_touch_no", "luminosity", "photoperiod", "salinity")
data <- data %>%
mutate(across(all_of(number_vars), as.numeric))
summary(data)
data %>% count(study_species) %>%
ggplot(aes(x = study_species, y = n, fill= study_species)) +
geom_col() +
labs(title="Count by Species", x="Species", y="Count")
data %>% filter(trial_day == 1) %>%
count(study_species) %>%
ggplot(aes(x = study_species, y = n, fill= study_species)) +
geom_col() +
labs(title="Count by Species", x="Species", y="Count")
data %>% filter(trial_day == 1, condition == 10) %>%
count(study_species) %>%
ggplot(aes(x = study_species, y = n, fill= study_species)) +
geom_col() +
labs(title="Count by Species", x="Species", y="Count")
data %>% filter(trial_day == 1, condition == 10) %>%
count(study_species) %>%
ggplot(aes(x = study_species, y = n, fill= study_species)) +
geom_col() +
labs(title="Sample sizes by Species", x="Species", y="Count")
unique(data$condition)
